# Public site URL for canonical URLs and Open Graph (no trailing slash). Required in production.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Clerk (dashboard authentication) – get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
# Optional: redirect after sign-in/sign-up (defaults used if not set)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Optional: hero video section (after carousel). Section hidden if not set.
# Direct video or YouTube: youtube.com/watch?v=..., youtu.be/..., or https://example.com/video.mp4
# NEXT_PUBLIC_HERO_VIDEO_URL=https://www.youtube.com/watch?v=VIDEO_ID
# NEXT_PUBLIC_HERO_VIDEO_POSTER_URL=https://example.com/poster.jpg
